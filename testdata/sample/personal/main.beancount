option "operating_currency" "BRL"

2020-01-01 open Assets:Cash
2020-01-01 open Assets:Broker:X
2020-01-01 open Expenses:Food
2020-01-01 open Income:Gains

2020-01-05 * "Lunch"
  Assets:Cash       -30.00 BRL
  Expenses:Food

2020-01-10 * "Buy"
  Assets:Broker:X    10 X {10.00 BRL}
  Assets:Cash

2020-02-10 * "Buy more"
  Assets:Broker:X    10 X {20.00 BRL}
  Assets:Cash

2020-03-10 * "Sell"
  Assets:Broker:X    -5 X @@ 100.00 BRL
  Assets:Cash         100.00 BRL
  Income:Gains
