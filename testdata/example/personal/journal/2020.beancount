; 2020 — opening, spending, average-cost buys, partial sell, pad.
; Mix of narration-only and payee+narration forms.

2020-01-01 * "Opening balances"
  Assets:Cash                 1000.00 BRL
  Equity:Opening-Balances

; Narration only (single quoted string).
2020-01-05 * "Lunch"
  Assets:Cash                  -30.00 BRL
  Expenses:Food

; Payee + narration (two quoted strings).
2020-01-10 * "Clearinghouse B3" "Buy X @ 10"
  Assets:Broker:X                10 X {10.00 BRL}
  Assets:Cash

2020-02-01 * "Employer SA" "Salary"
  Assets:Bank:Checking        5000.00 BRL
  Income:Salary

2020-02-05 * "Landlord" "Rent"
  Assets:Bank:Checking       -1500.00 BRL
  Expenses:Rent

; Narration only again.
2020-02-10 * "Buy more X @ 20 (avg → 15)"
  Assets:Broker:X                10 X {20.00 BRL}
  Assets:Cash

2020-03-10 * "Clearinghouse B3" "Sell 5 X for 100 total (avg cost 75 → gain 25)"
  Assets:Broker:X                -5 X @@ 100.00 BRL
  Assets:Cash                  100.00 BRL
  Income:Gains

; Pad + balance assertion: after lunch/buys/sell cash is messy;
; assert bank checking and use pad to force cash into known value.
2020-04-01 pad Assets:Cash Equity:Opening-Balances
2020-04-01 balance Assets:Cash 500.00 BRL

2020-06-15 * "Broker" "Monthly fee"
  Assets:Cash                   -5.00 BRL
  Expenses:Fees
