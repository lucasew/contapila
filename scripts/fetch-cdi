#!/usr/bin/env python3
# Fetch CDI over/diária (BCB SGS series 12) → contapila ingest JSONL on stdout.
# Stdlib only. Logs go to stderr.
#
#   ./scripts/fetch-cdi --from 2025-01-01 --to 2025-12-31 \
#     | contapila ingest --file indexes.beancount
#
#   contapila ingest --file indexes.beancount -- ./scripts/fetch-cdi --from 2025-01-01
#
# Series 12 is published as % a.d. (e.g. 0.052531). We emit daily_return = valor/100.

from __future__ import annotations

import argparse
import json
import ssl
import sys
import urllib.error
import urllib.parse
import urllib.request
from datetime import date, datetime
from decimal import Decimal, InvalidOperation

SGS_CDI = 12
SGS_URL = "https://api.bcb.gov.br/dados/serie/bcdata.sgs.{id}/dados"


def eprint(*args: object) -> None:
    print(*args, file=sys.stderr)


def parse_iso(s: str) -> date:
    return datetime.strptime(s, "%Y-%m-%d").date()


def br_date(d: date) -> str:
    return d.strftime("%d/%m/%Y")


def ssl_context(insecure: bool) -> ssl.SSLContext:
    if insecure:
        eprint("fetch-cdi: warning: TLS verification disabled (--insecure)")
        return ssl._create_unverified_context()
    return ssl.create_default_context()


def fetch_sgs(series_id: int, start: date, end: date, insecure: bool) -> list:
    q = urllib.parse.urlencode(
        {
            "formato": "json",
            "dataInicial": br_date(start),
            "dataFinal": br_date(end),
        }
    )
    url = f"{SGS_URL.format(id=series_id)}?{q}"
    eprint(f"fetch-cdi: GET series {series_id} {start.isoformat()}..{end.isoformat()}")
    req = urllib.request.Request(url, headers={"User-Agent": "contapila-fetch-cdi/1"})
    try:
        with urllib.request.urlopen(req, context=ssl_context(insecure), timeout=60) as resp:
            body = resp.read()
    except urllib.error.HTTPError as ex:
        eprint(f"fetch-cdi: HTTP {ex.code}: {ex.reason}")
        raise SystemExit(1) from ex
    except urllib.error.URLError as ex:
        eprint(f"fetch-cdi: network error: {ex.reason}")
        if not insecure and "CERTIFICATE" in str(ex.reason).upper():
            eprint("fetch-cdi: hint: retry with --insecure if your CA store is broken")
        raise SystemExit(1) from ex

    try:
        data = json.loads(body.decode("utf-8"))
    except json.JSONDecodeError as ex:
        eprint(f"fetch-cdi: invalid JSON from BCB: {ex}")
        raise SystemExit(1) from ex
    if not isinstance(data, list):
        eprint(f"fetch-cdi: unexpected payload type {type(data).__name__}")
        raise SystemExit(1)
    eprint(f"fetch-cdi: {len(data)} points from BCB")
    return data


def emit_jsonl(rows: list, name: str) -> int:
    n = 0
    for row in rows:
        try:
            raw_d = row["data"]
            raw_v = str(row["valor"]).strip().replace(",", ".")
            d = datetime.strptime(raw_d, "%d/%m/%Y").date()
            v = Decimal(raw_v)
        except (KeyError, TypeError, ValueError, InvalidOperation) as ex:
            eprint(f"fetch-cdi: skip bad row {row!r}: {ex}")
            continue
        rate = v / Decimal(100)  # % a.d. → daily return
        rate_s = format(rate, "f")
        obj = {
            "type": "custom",
            "date": d.isoformat(),
            "id": f"index:{name}:{d.isoformat()}",
            "custom_type": "index",
            "values": [
                {"text": name},
                {"number": rate_s},
            ],
        }
        sys.stdout.write(json.dumps(obj, ensure_ascii=False, separators=(",", ":")) + "\n")
        n += 1
    eprint(f"fetch-cdi: wrote {n} JSONL lines")
    return n


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(
        description="Fetch BCB CDI (SGS 12) as contapila ingest JSONL (stdout).",
    )
    p.add_argument("--from", dest="date_from", required=True, metavar="YYYY-MM-DD")
    p.add_argument("--to", dest="date_to", default=None, metavar="YYYY-MM-DD", help="default: today")
    p.add_argument("--name", default="CDI", help="index name (default: CDI)")
    p.add_argument(
        "--insecure",
        action="store_true",
        help="disable TLS certificate verification (broken corporate/Nix CA stores)",
    )
    args = p.parse_args(argv)

    start = parse_iso(args.date_from)
    end = parse_iso(args.date_to) if args.date_to else date.today()
    if end < start:
        eprint("fetch-cdi: --to is before --from")
        return 1

    rows = fetch_sgs(SGS_CDI, start, end, insecure=args.insecure)
    emit_jsonl(rows, name=args.name)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
